# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-strong-password

# DATABASE_URL goes through PgBouncer when deployed with a pooler; for the
# plain docker-compose stack it points directly to the db service.
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@db:5432/webstudio

# DIRECT_URL bypasses PgBouncer for schema migrations. Use the same value as
# DATABASE_URL when there is no connection pooler.
DIRECT_URL=postgresql://postgres:${POSTGRES_PASSWORD}@db:5432/webstudio

# ── PostgREST ─────────────────────────────────────────────────────────────────
# Generate with: node -e "require('crypto').randomBytes(64).toString('hex')"
PGRST_JWT_SECRET=change-me-64-char-minimum-secret-generate-with-the-command-above

# JWT signed with PGRST_JWT_SECRET, payload: {"role":"anon"}
# Optional: auto-derived from PGRST_JWT_SECRET at startup if left empty.
# Generate manually with: node -e "const j=require('jsonwebtoken');console.log(j.sign({role:'anon'},process.env.PGRST_JWT_SECRET))"
POSTGREST_API_KEY=

# ── Authentication ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
AUTH_SECRET=change-me

# Option A — simple dev login (password = AUTH_SECRET value)
DEV_LOGIN=true
# DEV_LOGIN_EMAIL=admin@example.com

# Option B — OAuth via GitHub (comment out DEV_LOGIN and fill these in)
# GH_CLIENT_ID=
# GH_CLIENT_SECRET=

# Option C — OAuth via Google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Feature flags ─────────────────────────────────────────────────────────────
FEATURES=*
USER_PLAN=pro
MAX_ASSETS_PER_PROJECT=50

# ── Asset storage ─────────────────────────────────────────────────────────────
# Leave blank to store uploads in a Docker volume (./public/s/uploads).
# Fill in S3-compatible credentials to use remote object storage instead.
# S3_ENDPOINT=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=
