{
  "name": "@webstudio-is/sdk",
  "version": "0.0.0-webstudio-version",
  "description": "Webstudio project data schema",
  "author": "Webstudio <github@webstudio.is>",
  "homepage": "https://webstudio.is",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "exports": {
    ".": {
      "webstudio": "./src/index.ts",
      "partykit": "./src/index.ts",
      "types": "./lib/types/index.d.ts",
      "import": "./lib/index.js"
    },
    "./runtime": {
      "webstudio": "./src/runtime.ts",
      "types": "./lib/types/runtime.d.ts",
      "import": "./lib/runtime.js"
    },
    "./schema-org": {
      "webstudio": "./src/schema-org.ts",
      "types": "./lib/types/schema-org.d.ts",
      "import": "./lib/schema-org.js"
    },
    "./link-utils": {
      "webstudio": "./src/link-utils.ts",
      "types": "./lib/types/link-utils.d.ts",
      "import": "./lib/link-utils.js"
    },
    "./schema": {
      "webstudio": "./src/schema.ts",
      "types": "./lib/types/schema.d.ts",
      "import": "./lib/schema.js"
    },
    "./normalize.css": {
      "webstudio": "./src/__generated__/normalize.css.ts",
      "types": "./lib/types/__generated__/normalize.css.d.ts",
      "import": "./lib/__generated__/normalize.css.js"
    },
    "./core-templates": {
      "webstudio": "./src/core-templates.tsx",
      "types": "./lib/types/core-templates.d.ts",
      "import": "./lib/core-templates.js"
    },
    "./router-path-test-data": {
      "webstudio": "./src/router-path-test-data.ts"
    },
    "./testing": {
      "webstudio": "./src/testing.ts"
    }
  },
  "files": [
    "lib/*",
    "!*.{test,stories}.*"
  ],
  "sideEffects": false,
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run",
    "build:schema-org-data": "tsx scripts/schema-org-data.ts && oxfmt src/__generated__/schema-org-data.ts",
    "build:normalize.css": "tsx --conditions=webstudio ./scripts/normalize.css.ts && oxfmt src/__generated__/normalize.css.ts",
    "build": "rm -rf lib && esbuild src/index.ts src/runtime.ts src/schema-org.ts src/link-utils.ts src/schema.ts src/__generated__/normalize.css.ts src/core-templates.tsx --outdir=lib --bundle --format=esm --packages=external",
    "dts": "tsc --project tsconfig.dts.json"
  },
  "dependencies": {
    "@emotion/hash": "^0.9.2",
    "@webstudio-is/css-engine": "workspace:*",
    "@webstudio-is/fonts": "workspace:*",
    "@webstudio-is/icons": "workspace:*",
    "@webstudio-is/wsauth": "workspace:*",
    "acorn": "^8.14.1",
    "acorn-walk": "^8.3.4",
    "change-case": "^5.4.4",
    "json-schema-typed": "^8.0.2",
    "reserved-identifiers": "^1.0.0",
    "type-fest": "^4.37.0",
    "warn-once": "^0.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@webstudio-is/css-data": "workspace:*",
    "@webstudio-is/template": "workspace:*",
    "@webstudio-is/tsconfig": "workspace:*",
    "html-tags": "^4.0.0",
    "papaparse": "^5.5.3",
    "@types/papaparse": "^5.5.2",
    "vitest": "^3.1.2"
  }
}
