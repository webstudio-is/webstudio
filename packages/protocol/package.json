{
  "name": "@webstudio-is/protocol",
  "version": "0.0.0-webstudio-version",
  "description": "Webstudio data exchange protocol contracts",
  "author": "Webstudio <github@webstudio.is>",
  "homepage": "https://webstudio.is",
  "type": "module",
  "scripts": {
    "build": "rm -rf lib && esbuild src/index.ts src/fixtures.ts --outdir=lib --bundle --format=esm --conditions=webstudio",
    "dts": "tsc --project tsconfig.dts.json",
    "test": "vitest run",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@webstudio-is/sdk": "workspace:*",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@webstudio-is/project-build": "workspace:*",
    "@webstudio-is/wsauth": "workspace:*",
    "@webstudio-is/tsconfig": "workspace:*",
    "vitest": "^3.1.2"
  },
  "exports": {
    ".": {
      "webstudio": "./src/index.ts",
      "types": "./lib/types/index.d.ts",
      "import": "./lib/index.js",
      "default": "./src/index.ts"
    },
    "./fixtures": {
      "webstudio": "./src/fixtures.ts",
      "types": "./lib/types/fixtures.d.ts",
      "import": "./lib/fixtures.js",
      "default": "./src/fixtures.ts"
    }
  },
  "files": [
    "lib/*",
    "!*.{test,stories}.*"
  ],
  "license": "AGPL-3.0-or-later",
  "private": false,
  "sideEffects": false
}
