{
  "name": "@webstudio-is/project-build",
  "version": "0.0.0",
  "description": "Webstudio Project Build",
  "author": "Webstudio <github@webstudio.is>",
  "homepage": "https://webstudio.is",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "webstudio": "./src/index.ts",
      "partykit": "./src/index.ts"
    },
    "./contracts": {
      "webstudio": "./src/contracts.ts",
      "import": "./src/contracts.ts",
      "default": "./src/contracts.ts"
    },
    "./runtime": {
      "webstudio": "./src/runtime.ts",
      "import": "./src/runtime.ts",
      "default": "./src/runtime.ts"
    },
    "./transfer": {
      "webstudio": "./src/transfer.ts",
      "import": "./src/transfer.ts",
      "default": "./src/transfer.ts"
    },
    "./transfer/server": {
      "webstudio": "./src/transfer.server.ts"
    },
    "./state": {
      "webstudio": "./src/state.ts",
      "import": "./src/state.ts",
      "default": "./src/state.ts"
    },
    "./project-session": {
      "webstudio": "./src/project-session.ts",
      "import": "./src/project-session.ts",
      "default": "./src/project-session.ts"
    },
    "./mcp": {
      "webstudio": "./src/mcp.ts"
    },
    "./visual": {
      "webstudio": "./src/visual.ts"
    },
    "./persistence": {
      "webstudio": "./src/persistence.ts",
      "import": "./src/persistence.ts",
      "default": "./src/persistence.ts"
    },
    "./server": {
      "webstudio": "./src/server.ts"
    }
  },
  "sideEffects": [
    "./src/state/immer.ts"
  ],
  "scripts": {
    "generate-docs": "node scripts/generate-docs.mjs && oxfmt src/docs.generated.ts",
    "generate-runtime-operation-contracts": "tsx --import ../../scripts/register-react-global.ts --conditions=webstudio scripts/generate-runtime-operation-contracts.ts && oxfmt src/contracts/__generated__/runtime-operation-contracts.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@emotion/hash": "^0.9.2",
    "@modelcontextprotocol/sdk": "^1.10.0",
    "@webstudio-is/authorization-token": "workspace:*",
    "@webstudio-is/css-data": "workspace:*",
    "@webstudio-is/css-engine": "workspace:*",
    "@webstudio-is/fonts": "workspace:*",
    "@webstudio-is/html-data": "workspace:*",
    "@webstudio-is/postgrest": "workspace:*",
    "@webstudio-is/project": "workspace:*",
    "@webstudio-is/project-migrations": "workspace:*",
    "@webstudio-is/react-sdk": "workspace:*",
    "@webstudio-is/sdk": "workspace:*",
    "@webstudio-is/sdk-components-registry": "workspace:*",
    "@webstudio-is/template": "workspace:*",
    "@webstudio-is/trpc-interface": "workspace:*",
    "@webstudio-is/wsauth": "workspace:*",
    "acorn": "^8.14.1",
    "acorn-jsx": "^5.3.2",
    "allof-merge": "^0.6.8",
    "bcp-47": "^2.1.0",
    "css-tree": "^3.1.0",
    "esbuild": "^0.25.3",
    "fast-deep-equal": "^3.1.3",
    "fast-png": "8.0.0",
    "immer": "^10.1.1",
    "nanoid": "^5.1.5",
    "papaparse": "^5.5.3",
    "parse5": "7.3.0",
    "slugify": "^1.6.6",
    "title-case": "^4.3.2",
    "urlpattern-polyfill": "^10.1.0",
    "valid-filename": "^4.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/papaparse": "^5.5.2",
    "@webstudio-is/tsconfig": "workspace:*",
    "vitest": "^3.1.2"
  }
}
